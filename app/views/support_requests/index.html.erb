<ul class="space-y-6">
  <% @support_requests.each do |support_request| %>
    <li class="bg-white p-5 rounded-lg shadow">

      <h2 class="text-lg font-semibold mb-2">
        On <%= support_request.created_at.to_formatted_s(:long) %>
        <code class="text-sm text-gray-600"><%= support_request.email %></code> writes:
      </h2>

      <blockquote class="border-l-4 pl-4 italic text-gray-700 mb-4">
        <h3 class="font-semibold text-base mb-1">
          <%= support_request.subject %>
        </h3>
        <p><%= support_request.body %></p>
      </blockquote>

      <% if support_request.order %>
        <h3 class="font-semibold mt-4 mb-2">Recent Order</h3>

        <dl class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
          <dt class="font-medium">Name</dt>
          <dd><%= support_request.order.name %></dd>

          <dt class="font-medium">Email</dt>
          <dd><%= support_request.order.email %></dd>

          <dt class="font-medium">Address</dt>
          <dd><%= support_request.order.address %></dd>

          <dt class="font-medium">PayType</dt>
          <dd><%= support_request.order.pay_type %></dd>
        </dl>

        <div class="mt-3">
          <h4 class="font-medium">Line Items</h4>
          <ul class="list-disc ml-5 text-sm">
            <% support_request.order.line_items.each do |line_item| %>
              <li>
                <%= line_item.product.title %>
                (<%= line_item.product.price %>)
              </li>
            <% end %>
          </ul>
        </div>

      <% else %>
        <h3 class="text-yellow-600 font-medium mt-3">
          No associated order
        </h3>
      <% end %>

      <!-- RESPONSE SECTION -->
      <div class="mt-5 border-t pt-4">
        <% if support_request.response.blank? %>
          <%= form_with(model: support_request, local: true, class: "space-y-3") do |form| %>

            <div>
              <%= form.label :response, "Write Response", class: "block font-medium mb-1" %>
              <%= form.rich_text_area :response, id: :support_request_response, class: "w-full" %>
            </div>

            <div>
              <%= form.submit "Send Response",
                              class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
            </div>

          <% end %>
        <% else %>
          <h4 class="font-semibold mb-1">Our response:</h4>
          <blockquote class="border-l-4 pl-4 italic text-gray-700">
            <%= support_request.response %>
          </blockquote>
        <% end %>
      </div>

    </li>
  <% end %>
</ul>