<%= form_with(model: order, class: "max-w-xl mx-auto bg-white p-6 rounded-xl shadow space-y-5") do |form| %>
  <% session[:idem_key] ||= SecureRandom.uuid %>
  <%= hidden_field_tag :idempotency_key, session[:idem_key] %>

  <% if order.errors.any? %>
    <div class="bg-red-50 text-red-600 px-4 py-3 rounded-lg">
      <h2 class="font-semibold mb-2">
        <%= pluralize(order.errors.count, "error") %> prevented this order:
      </h2>
      <ul class="list-disc ml-5 text-sm">
        <% order.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block font-medium mb-1" %>
    <%= form.text_field :name, class: "w-full input-field" %>
  </div>

  <div>
    <%= form.label :address, class: "block font-medium mb-1" %>
    <%= form.text_area :address, rows: 4, class: "w-full input-field" %>
  </div>

  <div>
    <%= form.label :email, class: "block font-medium mb-1" %>
    <%= form.email_field :email, class: "w-full input-field" %>
  </div>

  <!-- Payment Section -->
  <div data-controller="payment" class="border-t pt-4">
    <h3 class="font-semibold mb-2">Payment Method</h3>

    <%= form.select :pay_type,
                    Order.pay_types.keys.map { |key| [t(".pay_types.#{key}"), key] },
                    { prompt: t('.pay_prompt_html') },
                    class: "w-full input-field",
                    data: {
                      payment_target: "selection",
                      action: "change->payment#showAdditionalFields"
                    } %>

    <!-- Dynamic fields -->
    <div class="mt-4 space-y-4">
      <%= render partial: 'check', locals: { form: form } %>
      <%= render partial: 'cc', locals: { form: form } %>
      <%= render partial: 'po', locals: { form: form } %>
    </div>
  </div>

  <div>
    <%= form.submit t('.submit'),
                    class: "w-full bg-green-600 text-white py-3 rounded-lg font-medium hover:bg-green-700 transition" %>
  </div>

<% end %>